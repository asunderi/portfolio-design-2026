---
interface Props {
	eyebrow: string;
	title: string;
	lede?: string;
	variant?: 'default' | 'hero';
}
const { eyebrow, title, lede, variant = 'default' } = Astro.props;
---

<header
	class:list={[
		'page-header container',
		variant === 'hero' && 'page-header--hero',
	]}
>
	<p class="eyebrow">{eyebrow}</p>
	<h1 class="page-header__title">{title}</h1>
	{lede && <p class="page-header__lede measure">{lede}</p>}
	<slot />
	{
		Astro.slots.has('actions') && (
			<div class="page-header__actions">
				<slot name="actions" />
			</div>
		)
	}
	{
		variant === 'hero' && (
			<a class="page-header__scroll" href="#main-content" aria-label="Scroll to see more">
				<span>Scroll to see more</span>
				<svg class="page-header__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M6 9l6 6 6-6" />
				</svg>
			</a>
		)
	}
</header>

<style>
	.page-header__scroll {
		position: absolute;
		left: 50%;
		bottom: var(--space-l);
		transform: translateX(-50%);
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2xs);
		font-family: var(--font-body);
		font-size: var(--step--1);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-muted);
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}
	.page-header__scroll:hover { color: var(--accent); }
	.page-header__chevron { animation: scroll-nudge 1.8s var(--ease) infinite; }
	@keyframes scroll-nudge {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(4px); }
	}
	@media (max-width: 40rem) {
		.page-header__scroll span { display: none; }
	}
</style>
