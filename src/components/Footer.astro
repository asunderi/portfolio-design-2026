---
const year = new Date().getFullYear();
const socials = [
	{ href: 'mailto:hello@anastacia.design', label: 'Email' },
	{ href: 'https://www.linkedin.com/', label: 'LinkedIn' },
];
---

<footer class="site-footer">
	<div class="container site-footer__inner">
		<p class="site-footer__mark">Anastacia Frost — Multidisciplinary Designer</p>
		<ul class="site-footer__links">
			{socials.map(({ href, label }) => (
				<li><a href={href}>{label}</a></li>
			))}
		</ul>
		<p class="site-footer__copy">&copy; {year}. All rights reserved.</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--line);
		padding-block: var(--space-l);
		margin-top: var(--space-2xl);
	}
	.site-footer__inner {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-s) var(--space-l);
		align-items: center;
		justify-content: space-between;
	}
	.site-footer__mark {
		font-family: var(--font-display);
		font-size: var(--step--1);
	}
	.site-footer__links {
		display: flex;
		gap: var(--space-m);
		list-style: none;
		padding: 0;
		font-size: var(--step--1);
	}
	.site-footer__links a {
		position: relative;
		color: var(--accent);
		text-decoration: none;
	}
	/* Underline drags in left-to-right */
	.site-footer__links a::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1.5px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.25s var(--ease);
	}
	.site-footer__links a:hover::after { transform: scaleX(1); }
	.site-footer__copy {
		font-size: var(--step--1);
		color: var(--ink-muted);
	}
</style>
