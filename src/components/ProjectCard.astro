---
interface Props {
	id: string;
	title: string;
	summary: string;
	dateLabel: string;
	type?: string[];
	tools?: string[];
}
const { id, title, summary, dateLabel, type = [], tools = [] } = Astro.props;
const tags = (type.length ? type : tools).slice(0, 3);
---

<a href={`/work/${id}`} class="card">
	<div class="card__head">
		<span class="card__year">{dateLabel}</span>
		{tags[0] && <span class="card__kicker">{tags[0]}</span>}
	</div>
	<h3 class="card__title">{title}</h3>
	<p class="card__summary">{summary}</p>
	<div class="card__foot">
		<ul class="card__tags">
			{tags.map((t) => <li>{t}</li>)}
		</ul>
		<span class="card__cta" aria-hidden="true">→</span>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-l) var(--space-m);
		background: var(--bg-elev);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
		transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
	}
	/* Whole card grows slightly, border tints, shadow static, no lift */
	.card:hover {
		border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
		transform: scale(1.02);
	}
	.card__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-s);
		font-size: var(--step--1);
		color: var(--ink-muted);
	}
	.card__year { font-variant-numeric: tabular-nums; }
	.card__kicker {
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.72em;
		font-weight: 500;
	}
	.card__title {
		font-size: var(--step-3);
		margin-top: var(--space-2xs);
		transition: color 0.25s var(--ease);
	}
	.card:hover .card__title { color: var(--accent); }
	.card__summary { color: var(--ink-muted); }
	.card__foot {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: var(--space-s);
		margin-top: auto;
		padding-top: var(--space-s);
	}
	.card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
		list-style: none;
		padding: 0;
	}
	.card__tags li {
		font-size: var(--step--1);
		padding: 0.15em 0.6em;
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--ink-muted);
	}
	.card__cta {
		font-size: var(--step-2);
		color: var(--accent);
	}
</style>
