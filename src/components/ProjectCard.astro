---
interface Props {
	id: string;
	title: string;
	summary: string;
	year: number;
	tools: string[];
}
const { id, title, summary, year, tools } = Astro.props;
---

<a href={`/work/${id}`} class="card">
	<div class="card__head">
		<h3 class="card__title">{title}</h3>
		<span class="card__year">{year}</span>
	</div>
	<p class="card__summary">{summary}</p>
	<ul class="card__tools">
		{tools.map((t) => <li>{t}</li>)}
	</ul>
	<span class="card__cta">View project →</span>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-m);
		background: var(--bg-elev);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		transition: transform 0.25s var(--ease), border-color 0.25s var(--ease);
	}
	.card:hover {
		transform: translateY(-4px);
		border-color: var(--accent);
	}
	.card__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-s);
	}
	.card__title { font-size: var(--step-2); }
	.card__year {
		font-family: var(--font-display);
		font-size: var(--step--1);
		color: var(--ink-muted);
	}
	.card__summary { color: var(--ink-muted); }
	.card__tools {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
		list-style: none;
		padding: 0;
		margin-top: auto;
	}
	.card__tools li {
		font-size: var(--step--1);
		padding: 0.2em 0.7em;
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--ink-muted);
	}
	.card__cta {
		font-family: var(--font-display);
		font-size: var(--step--1);
		color: var(--accent);
		margin-top: var(--space-2xs);
	}
</style>
