// TODO: confirm hello@anastacia.design alias actually routes to inbox
// (anastacia.lt.frost@gmail.com) before relying on it. Used here + in
// Footer, Header, and the home hero.
---

<section id="contact" class="section container">
	<div class="section-head">
		<p class="eyebrow">Contact</p>
		<h2>Say hi.</h2>
		<p class="section-head__lede">
			Always up to talk shop. Drop me a line.
		</p>
	</div>
	<div class="contact-cta__actions">
		<a class="button" href="mailto:hello@anastacia.design">Email me</a>
		<a class="button button--ghost" href="https://www.linkedin.com/" rel="me">
			LinkedIn
		</a>
	</div>
</section>

<style>
	#contact {
		scroll-margin-top: 5rem;
	}
	.contact-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-s);
	}
</style>
