---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'hello@anastacia.design';
const links = [
	{ href: `mailto:${email}`, label: email },
	{ href: 'https://www.linkedin.com/', label: 'LinkedIn' },
];
---

<BaseLayout
	title="Contact"
	description="Get in touch with Anastacia Frost for design, branding, and UI/UX work."
>
	<section class="container contact">
		<p class="eyebrow">Contact</p>
		<h1>Let's build something intentional.</h1>
		<p class="measure contact__lede">
			Have a project in mind, or just want to say hello? I'd love to hear about
			it.
		</p>
		<a class="button" href={`mailto:${email}`}>Email me</a>

		<ul class="contact__links">
			{links.map(({ href, label }) => (
				<li><a href={href}>{label}</a></li>
			))}
		</ul>
	</section>
</BaseLayout>

<style>
	.contact { padding-block: var(--space-2xl); }
	.contact h1 { font-size: var(--step-5); margin-top: var(--space-s); max-width: 16ch; }
	.contact__lede { font-size: var(--step-1); color: var(--ink-muted); margin-block: var(--space-m) var(--space-l); }
	.contact__links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-m);
		list-style: none;
		padding: 0;
		margin-top: var(--space-xl);
		padding-top: var(--space-l);
		border-top: 1px solid var(--line);
		font-family: var(--font-display);
	}
</style>
