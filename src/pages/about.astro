---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';

const skills = [
	'Graphic Design',
	'UI/UX',
	'Branding',
	'Infographics',
	'Web (HTML/SCSS)',
	'Design Systems',
];
const tools = [
	'Figma',
	'Illustrator',
	'InDesign',
	'Photoshop',
	'Adobe XD',
	'Affinity Suite',
];
---

<BaseLayout
	title="About"
	description="Anastacia Frost — a designer with nearly a decade of experience blending aesthetics with functionality."
>
	<PageHeader
		eyebrow="About"
		title="Designs that solve problems, tell stories, and connect."
	>
		<div class="prose measure flow">
			<p>
				I'm Anastacia — a designer with nearly a decade of experience blending
				aesthetics with functionality. I specialize in graphic design, UI/UX,
				branding, and infographics.
			</p>
			<p>
				My philosophy goes beyond surface-level beauty: I create designs that
				solve problems, tell stories, and build meaningful connections. Every
				project starts with intent and ends with something distinctly yours.
			</p>
			<p>
				Off the clock, you'll find me in creative communities, playing video
				games, watching horror films, and hanging out with my cat.
			</p>
		</div>
	</PageHeader>

	<section class="section container">
		<div class="section-head">
			<p class="eyebrow">Capabilities</p>
			<h2>Skills &amp; tools</h2>
		</div>
		<div class="two-col">
			<div>
				<h3>Skills &amp; expertise</h3>
				<ul class="tags">
					{skills.map((s) => <li>{s}</li>)}
				</ul>
			</div>
			<div>
				<h3>Tools</h3>
				<ul class="tags">
					{tools.map((t) => <li>{t}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<ContactCTA />
</BaseLayout>

<style>
	.prose {
		margin-top: var(--space-l);
		font-size: var(--step-1);
		color: var(--ink-muted);
	}
	.two-col {
		display: grid;
		gap: var(--space-xl);
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
	}
	.two-col h3 { font-size: var(--step-1); margin-bottom: var(--space-m); }
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
		list-style: none;
		padding: 0;
	}
	.tags li {
		font-family: var(--font-display);
		font-size: var(--step--1);
		padding: 0.35em 0.9em;
		border: 1px solid var(--line);
		border-radius: 999px;
	}
</style>
