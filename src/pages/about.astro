---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';

const skills = [
	'Graphic Design',
	'UI/UX',
	'User Flows & Journey Mapping',
	'Branding',
	'Infographics',
	'Front-end (HTML/SCSS, Vue)',
	'Design Systems',
];
const tools = [
	'Figma',
	'Illustrator',
	'InDesign',
	'Photoshop',
	'Affinity Suite',
];
const experience = [
	{
		role: 'Marketing Specialist – Web Designer',
		org: 'Centrica Care Navigators',
		years: '2026–Present',
		note: 'On a four-person marketing team handling everything web, from landing pages to user flows to turning print into digital.',
	},
	{
		role: 'Contractor / Freelance Designer',
		org: 'Freelance',
		years: '2022–Present',
		note: 'Design and build for clients across legal, media, and hospitality, usually the tangled briefs that need untangling before anything gets made.',
	},
	{
		role: 'UI/UX Designer',
		org: 'Consumers Energy',
		years: '2022',
		note: 'Mapped a scatter of separate work processes into one internal app, the journey-mapping kind of problem I like most.',
	},
	{
		role: 'Front End Developer',
		org: 'Kalamazoo Valley Community College',
		years: '2019–2022',
		note: 'Three years on a five-person web team building internal apps, a college-wide event platform, and enrollment guides in Laravel and Vue.',
	},
	{
		role: 'UI/UX Designer',
		org: 'ControlNET, LLC',
		years: '2015–2019',
		note: 'My longest brand engagement: a full rebrand, plus the interfaces, print, and web that carried it across the company.',
	},
	{
		role: 'Graphic Designer',
		org: 'S2Games',
		years: '2013–2014',
		note: 'My first real design job, making landing pages, hero-stat interfaces, and convention print for the MOBA game Strife.',
	},
];
---

<BaseLayout
	title="About"
	description="Anastacia Frost — a multidisciplinary designer who's been drawing since before she can remember."
>
	<PageHeader
		eyebrow="About"
		title="I'd rather make something that endures than something that just looks good."
	>
		<div class="prose measure flow">
			<p>
				I've been drawing since I was a kid — copying cartoon characters off the
				TV, taking every art class I could get into. Art was how I showed people
				what I felt before I had better words for it. By high school I'd found
				digital tools, and that was that.
			</p>
			<p>
				I studied graphic design, then spent the years since across a big pharma
				rebrand, a games studio, a college web team, and a stack of brands and
				apps. The throughline: I love taking a half-formed idea from someone who
				can't quite show what they mean — and being the hands that make it real.
				The more tangled the problem, the more I want it.
			</p>
			<p>
				Off the clock I'm in creative communities, deep in a video game,
				watching something horror, or being supervised by my cat.
			</p>
		</div>
	</PageHeader>

	<section class="section container">
		<div class="section-head">
			<p class="eyebrow">Experience</p>
			<h2>Where I've worked</h2>
			<p class="section-head__lede">
				More than fifteen years across brand, interface, and web — a few of
				the places that shaped how I work.
			</p>
		</div>
		<ul class="experience">
			{experience.map((job) => (
				<li class="experience__row">
					<div class="experience__head">
						<h3 class="experience__role">{job.role}</h3>
						<p class="experience__meta">{job.org} · {job.years}</p>
					</div>
					<p class="experience__note">{job.note}</p>
				</li>
			))}
		</ul>
		<p class="experience__earlier">
			Earlier: design &amp; web internships, Kalamazoo Valley Community College
			(2011–2012).
		</p>
	</section>

	<section class="section container">
		<div class="section-head">
			<p class="eyebrow">Capabilities</p>
			<h2>Skills &amp; tools</h2>
			<p class="section-head__lede">
				The range I lean on to take an idea from a clear scope to something
				that lasts.
			</p>
		</div>
		<div class="two-col">
			<div>
				<h3>Skills &amp; expertise</h3>
				<ul class="tags">
					{skills.map((s) => <li>{s}</li>)}
				</ul>
			</div>
			<div>
				<h3>Tools</h3>
				<ul class="tags">
					{tools.map((t) => <li>{t}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<ContactCTA />
</BaseLayout>

<style>
	.prose {
		margin-top: var(--space-l);
		font-size: var(--step-1);
		color: var(--ink-muted);
	}
	.two-col {
		display: grid;
		gap: var(--space-xl);
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
	}
	.two-col h3 { font-size: var(--step-1); margin-bottom: var(--space-m); }
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
		list-style: none;
		padding: 0;
	}
	.tags li {
		font-family: var(--font-display);
		font-size: var(--step--1);
		padding: 0.35em 0.9em;
		border: 1px solid var(--line);
		border-radius: 999px;
	}
	.experience {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.experience__row {
		display: grid;
		gap: var(--space-2xs);
		padding: var(--space-m) 0;
		border-top: 1px solid var(--line);
	}
	.experience__row:last-child {
		border-bottom: 1px solid var(--line);
	}
	.experience__head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-2xs) var(--space-m);
	}
	.experience__role {
		font-size: var(--step-1);
		margin: 0;
	}
	.experience__meta {
		font-family: var(--font-display);
		font-size: var(--step--1);
		color: var(--ink-muted);
		margin: 0;
	}
	.experience__note {
		max-width: var(--measure, 60ch);
		color: var(--ink-muted);
		margin: 0;
	}
	.experience__earlier {
		margin-top: var(--space-m);
		font-size: var(--step--1);
		color: var(--ink-muted);
	}
</style>
