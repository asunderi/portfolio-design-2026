---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';

const skills = [
	'Graphic Design',
	'UI/UX',
	'User Flows & Journey Mapping',
	'Branding',
	'Infographics',
	'Front-end (HTML/SCSS, Vue)',
	'Design Systems',
];
const tools = [
	'Figma',
	'Illustrator',
	'InDesign',
	'Photoshop',
	'Affinity Suite',
];
---

<BaseLayout
	title="About"
	description="Anastacia Frost — a multidisciplinary designer who's been drawing since before she can remember."
>
	<PageHeader
		eyebrow="About"
		title="A designer, for about as long as I can remember."
	>
		<div class="prose measure flow">
			<p>
				I've been drawing since I was a kid — copying cartoon characters off the
				TV, taking every art class I could get into. Art was how I showed people
				what I felt before I had better words for it. By high school I'd found
				digital tools, and that was that.
			</p>
			<p>
				I studied graphic design, then spent the years since across a big pharma
				rebrand, a games studio, a college web team, and a stack of brands and
				apps. The throughline: I love taking a half-formed idea from someone who
				can't quite show what they mean — and being the hands that make it real.
				The more tangled the problem, the more I want it.
			</p>
			<p>
				Off the clock I'm in creative communities, deep in a video game,
				watching something horror, or being supervised by my cat.
			</p>
		</div>
	</PageHeader>

	<section class="section container">
		<div class="section-head">
			<p class="eyebrow">Capabilities</p>
			<h2>Skills &amp; tools</h2>
		</div>
		<div class="two-col">
			<div>
				<h3>Skills &amp; expertise</h3>
				<ul class="tags">
					{skills.map((s) => <li>{s}</li>)}
				</ul>
			</div>
			<div>
				<h3>Tools</h3>
				<ul class="tags">
					{tools.map((t) => <li>{t}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<ContactCTA />
</BaseLayout>

<style>
	.prose {
		margin-top: var(--space-l);
		font-size: var(--step-1);
		color: var(--ink-muted);
	}
	.two-col {
		display: grid;
		gap: var(--space-xl);
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
	}
	.two-col h3 { font-size: var(--step-1); margin-bottom: var(--space-m); }
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xs);
		list-style: none;
		padding: 0;
	}
	.tags li {
		font-family: var(--font-display);
		font-size: var(--step--1);
		padding: 0.35em 0.9em;
		border: 1px solid var(--line);
		border-radius: 999px;
	}
</style>
