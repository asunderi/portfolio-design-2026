---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';

const projects = (await getCollection('projects'))
	.filter((p) => p.data.featured)
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Anastacia Frost">
	<PageHeader
		variant="hero"
		eyebrow="Anastacia Frost"
		title="I'm a designer who cares more about the problem than the pixels."
		lede="Nearly a decade turning fuzzy ideas into things that work, mean something, and feel like yours."
	>
		<Fragment slot="actions">
			<a class="button" href="/work">See my work</a>
			<a class="button button--ghost" href="mailto:hello@anastacia.design">Say hi</a>
		</Fragment>
	</PageHeader>

	<section class="section container">
		<div class="section-head">
			<p class="eyebrow">Work</p>
			<div class="section-head__bar">
				<h2>Featured work</h2>
				<a href="/work" class="section-head__link">All projects →</a>
			</div>
		</div>
		<div class="grid">
			{projects.map((p) => (
				<ProjectCard
					id={p.id}
					title={p.data.title}
					summary={p.data.summary}
					dateLabel={p.data.dateLabel ?? String(p.data.year)}
					type={p.data.type}
					tools={p.data.tools}
				/>
			))}
		</div>
	</section>

	<section class="section container about-teaser">
		<div class="section-head">
			<p class="eyebrow">About</p>
			<h2>A bit about me</h2>
			<p class="section-head__lede">
				I've been drawing since before I can remember — these days I do it for
				brands, interfaces, and the people who can't quite picture what they
				want yet.
			</p>
		</div>
		<a class="about-teaser__link" href="/about">More about me &rarr;</a>
	</section>

	<ContactCTA />
</BaseLayout>

<style>
	.about-teaser__link {
		display: inline-block;
		font-weight: 500;
		color: var(--accent);
		text-decoration: none;
	}
	.about-teaser__link:hover {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
</style>
