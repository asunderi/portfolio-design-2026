---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';

const projects = (await getCollection('projects'))
	.filter((p) => p.data.featured)
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Anastacia Frost">
	<PageHeader
		variant="hero"
		eyebrow="Multidisciplinary Designer"
		title="Anastacia Frost"
		lede="Beautiful design comes from well-defined scope."
	>
		<p class="hero-support measure">
			When I start something, I work inside its limits while thinking about the
			long haul: how it'll hold up, grow, and endure. More than fifteen years
			of exactly that, across brand, interface, and web.
		</p>
		<Fragment slot="actions">
			<a class="button" href="/work">See my work</a>
			<a class="button button--ghost" href="mailto:hello@anastacia.design">Say hi</a>
		</Fragment>
	</PageHeader>

	<section class="section container">
		<div class="section-head">
			<p class="eyebrow">Work</p>
			<div class="section-head__bar">
				<h2>Featured work</h2>
				<a href="/work" class="section-head__link">All projects →</a>
			</div>
		</div>
		<div class="grid">
			{projects.map((p) => (
				<ProjectCard
					id={p.id}
					title={p.data.title}
					summary={p.data.summary}
					dateLabel={p.data.dateLabel ?? String(p.data.year)}
					type={p.data.type}
					tools={p.data.tools}
				/>
			))}
		</div>
	</section>

	<section class="section container about-teaser">
		<div class="section-head">
			<p class="eyebrow">About</p>
			<h2>A bit about me</h2>
			<p class="section-head__lede">
				I've been drawing since before I can remember. These days it goes into
				brand, interface, and web — work I'd rather see hold up than just stand
				out.
			</p>
		</div>
		<a class="about-teaser__link" href="/about">More about me &rarr;</a>
	</section>

	<ContactCTA />
</BaseLayout>

<style>
	.hero-support {
		margin-top: var(--space-m);
		color: var(--ink-muted);
	}
	.about-teaser__link {
		display: inline-block;
		font-weight: 500;
		color: var(--accent);
		text-decoration: none;
	}
	.about-teaser__link:hover {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
</style>
