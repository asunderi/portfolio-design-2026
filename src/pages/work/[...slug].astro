---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

export async function getStaticPaths() {
	const projects = (await getCollection('projects')).sort(
		(a, b) => a.data.order - b.data.order,
	);
	const len = projects.length;
	return projects.map((project, i) => ({
		params: { slug: project.id },
		props: {
			project,
			next: projects[(i + 1) % len],
			// Two follow-on projects (wrapping), for the footer card grid.
			more: [projects[(i + 1) % len], projects[(i + 2) % len]].filter(
				(p) => p.id !== project.id,
			),
		},
	}));
}

const { project, next, more } = Astro.props;
const { Content, headings } = await render(project);
const { title, shortTitle, summary, year, dateLabel, role, type, tools, client, cover } =
	project.data;

const meta = [
	{ label: 'Year', value: dateLabel ?? String(year) },
	{ label: 'Role', value: role },
	{ label: 'Client', value: client },
	{ label: 'Discipline', value: type.length ? type.join(', ') : undefined },
	{ label: 'Tools', value: tools.length ? tools.join(', ') : undefined },
].filter((m) => m.value);

// Section list for the content-peek (h2s only). Need at least 2 to be useful.
const sections = headings.filter((h) => h.depth === 2);
const hasPeek = sections.length > 1;
---

<BaseLayout title={title} description={summary}>
	<article>
		<nav class="container project__nav" id="top">
			<a href="/work" class="project__back">← All work</a>
			{next && next.id !== project.id && (
				<a href={`/work/${next.id}`} class="project__back project__next">
					{next.data.title} →
				</a>
			)}
		</nav>

		<div class="project__cover">
			{cover ? (
				<img src={cover} alt={`${title} — cover`} />
			) : (
				<div class="project__cover-ph" role="img" aria-label={`Placeholder: ${title} cover`}>
					<span class="project__cover-label">{title} — cover</span>
					<span class="project__cover-ratio">full-bleed banner</span>
				</div>
			)}
		</div>

		<div class:list={['container project__layout', hasPeek && 'project__layout--peek']}>
			{hasPeek && (
				<aside class="peek" aria-label="On this page">
					<div class="peek__sticky">
						<p class="peek__label">{shortTitle ?? title}</p>
						<nav class="peek__nav">
							<span class="peek__spine" aria-hidden="true">
								<span class="peek__spine-fill" data-peek-fill></span>
							</span>
							<ol class="peek__list">
								<li class="peek__item">
									<a href="#top" class="peek__link" data-peek-link="top">
										<span class="peek__num">00</span>
										<span class="peek__text">Top</span>
									</a>
								</li>
								{sections.map((s, i) => (
									<li class="peek__item">
										<a href={`#${s.slug}`} class="peek__link" data-peek-link={s.slug}>
											<span class="peek__num">{String(i + 1).padStart(2, '0')}</span>
											<span class="peek__text">{s.text}</span>
										</a>
									</li>
								))}
							</ol>
						</nav>
					</div>
				</aside>
			)}

			<div class="project__main">
				<header class="project__header">
					<h1 class="project__title">{title}</h1>
					<p class="project__summary measure">{summary}</p>

					<dl class="meta">
						{meta.map((m) => (
							<div class="meta__item">
								<dt>{m.label}</dt>
								<dd>{m.value}</dd>
							</div>
						))}
					</dl>
				</header>

				<div class="project__body flow measure">
					<Content />
				</div>
			</div>
		</div>

		{more.length > 0 && (
			<section class="container project__more">
				<div class="section-head">
					<p class="eyebrow">Keep looking</p>
					<div class="section-head__bar">
						<h2>Check out these other projects</h2>
						<a href="/work" class="section-head__link">All work →</a>
					</div>
				</div>
				<div class="grid">
					{more.map((p) => (
						<ProjectCard
							id={p.id}
							title={p.data.title}
							summary={p.data.summary}
							dateLabel={p.data.dateLabel ?? String(p.data.year)}
							type={p.data.type}
							tools={p.data.tools}
						/>
					))}
				</div>
			</section>
		)}
	</article>
</BaseLayout>

<style>
	/* Full-bleed banner, flush to top under the site header */
	.project__cover {
		width: 100vw;
		margin-inline: calc(50% - 50vw);
	}
	.project__cover img,
	.project__cover-ph {
		display: block;
		width: 100%;
		height: clamp(180px, 30vw, 360px);
		object-fit: cover;
	}
	.project__cover-ph {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-2xs);
		text-align: center;
		background: var(--bg-elev);
		border-block: 1.5px dashed var(--line);
	}
	.project__cover-label {
		font-family: var(--font-display);
		font-size: var(--step-1);
		color: var(--ink-muted);
	}
	.project__cover-ratio {
		font-size: var(--step--1);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-muted);
		opacity: 0.7;
	}
	/* Layout: single column by default. --bleed-left tells nested figures how
	   far the content column sits from the viewport's left edge, so full/wide
	   figures can still break out to the viewport. */
	.project__layout {
		--peek-w: 12rem;
		--bleed-left: calc(max((100vw - var(--container)) / 2, 0px) + var(--space-m));
	}
	/* Two-column with sticky content-peek on the left, content shifted right. */
	@media (min-width: 60rem) {
		.project__layout--peek {
			display: grid;
			grid-template-columns: var(--peek-w) minmax(0, 1fr);
			gap: var(--space-xl);
			--bleed-left: calc(
				max((100vw - var(--container)) / 2, 0px) + var(--space-m) +
					var(--peek-w) + var(--space-xl)
			);
		}
	}

	/* Content-peek */
	.peek { display: none; }
	@media (min-width: 60rem) { .peek { display: block; } }
	.peek__sticky {
		position: sticky;
		top: calc(4rem + var(--space-l));
		/* Align label with the project title: header top-pad + title margin,
		   less the card's own top padding. */
		margin-top: calc(var(--space-l) + var(--space-m) - var(--space-xs));
		padding: var(--space-xs) var(--space-s);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		/* Glass: frosts over images/content that bleed under the column */
		background: color-mix(in srgb, var(--bg) 70%, transparent);
		backdrop-filter: blur(10px) saturate(1.4);
		-webkit-backdrop-filter: blur(10px) saturate(1.4);
	}
	.peek__label {
		font-size: var(--step--1);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-muted);
		margin-bottom: var(--space-xs);
	}
	.peek__nav { position: relative; }
	/* Spine = full track; fill grows top→down with scroll progress */
	.peek__spine {
		position: absolute;
		left: 1px;
		top: 0.45em;
		bottom: 0.45em;
		width: 1.5px;
		background: var(--line);
	}
	.peek__spine-fill {
		position: absolute;
		inset: 0 auto auto 0;
		width: 1.5px;
		height: 0;
		background: var(--accent);
		transition: height 0.15s linear;
	}
	.peek__list {
		list-style: none;
		margin: 0;
		padding: 0 0 0 var(--space-s);
	}
	.peek__item + .peek__item { margin-top: var(--space-2xs); }
	.peek__link {
		display: flex;
		gap: var(--space-2xs);
		font-size: var(--step--1);
		line-height: 1.3;
		color: var(--ink-muted);
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}
	.peek__num {
		font-variant-numeric: tabular-nums;
		font-size: 0.75em;
		line-height: inherit;
		align-self: center;
		opacity: 0.55;
		transition: opacity 0.2s var(--ease);
	}
	.peek__link:hover { color: var(--accent); }
	.peek__link.is-active { color: var(--accent); }
	.peek__link.is-active .peek__num { opacity: 1; }

	.project__header { padding-block: var(--space-l); }
	.project__nav {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: var(--space-m);
		padding-block: var(--space-m);
		scroll-margin-top: 4rem;
	}
	.project__back {
		position: relative;
		font-family: var(--font-display);
		font-size: var(--step--1);
		color: var(--accent);
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}
	/* Underline drags in left-to-right */
	.project__back::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1.5px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.25s var(--ease);
	}
	.project__back:hover::after { transform: scaleX(1); }
	/* Next link mirrors: text right-aligned, underline drags in right-to-left */
	.project__next { text-align: right; }
	.project__next::after { transform-origin: right; }
	.project__title { font-size: var(--step-5); margin-top: var(--space-m); }
	.project__summary { font-size: var(--step-1); color: var(--ink-muted); margin-top: var(--space-s); }
	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-l);
		margin-top: var(--space-l);
		padding-top: var(--space-m);
		border-top: 1px solid var(--line);
	}
	.meta__item dt {
		font-size: var(--step--1);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-muted);
	}
	.meta__item dd {
		font-family: var(--font-display);
		margin: 0;
	}
	.project__body { padding-bottom: var(--space-2xl); font-size: var(--step-0); }
	.project__body :global(h2) {
		font-size: var(--step-3);
		margin-top: var(--space-xl);
		margin-bottom: var(--space-2xs);
		scroll-margin-top: calc(4rem + var(--space-m));
	}
	.project__body :global(h3) {
		font-size: var(--step-1);
		margin-top: var(--space-l);
		margin-bottom: var(--space-2xs);
	}
	.project__body :global(p) { color: var(--ink); }
	.project__body :global(ul) {
		padding-left: 1.2em;
		color: var(--ink-muted);
	}
	.project__body :global(li) { margin-top: var(--space-2xs); }
	.project__body :global(li)::marker { color: var(--accent); }
	.project__body :global(strong) { color: var(--ink); font-weight: 500; }
	.project__body :global(a) { color: var(--accent); }
	.project__body :global(hr) {
		border: 0;
		height: 1px;
		background: var(--line);
		margin-block: var(--space-l);
	}
	.project__more {
		padding-block: var(--space-2xl);
		border-top: 1px solid var(--line);
	}
</style>

<script>
	// Content-peek: highlight the active section + fill the spine with scroll
	// progress. One rAF-throttled handler for scroll + resize.
	(() => {
		const links = [
			...document.querySelectorAll<HTMLElement>('[data-peek-link]'),
		];
		if (!links.length) return;

		const fill = document.querySelector<HTMLElement>('[data-peek-fill]');
		const body = document.querySelector<HTMLElement>('.project__body');
		const targets = links
			.map((link) => ({
				link,
				el: document.getElementById(link.dataset.peekLink ?? ''),
			}))
			.filter((t): t is { link: HTMLElement; el: HTMLElement } => !!t.el);

		let ticking = false;
		const update = () => {
			ticking = false;
			const threshold = window.innerHeight * 0.3;

			let active = targets[0];
			for (const t of targets) {
				if (t.el.getBoundingClientRect().top <= threshold) active = t;
			}
			for (const link of links) {
				link.classList.toggle('is-active', link === active.link);
			}

			if (fill && body) {
				const rect = body.getBoundingClientRect();
				const total = rect.height - window.innerHeight;
				const seen = Math.min(Math.max(-rect.top, 0), Math.max(total, 0));
				const pct = total > 0 ? seen / total : rect.top <= 0 ? 1 : 0;
				fill.style.height = (pct * 100).toFixed(1) + '%';
			}
		};
		const onScroll = () => {
			if (!ticking) {
				ticking = true;
				requestAnimationFrame(update);
			}
		};

		addEventListener('scroll', onScroll, { passive: true });
		addEventListener('resize', onScroll, { passive: true });
		update();
	})();
</script>
