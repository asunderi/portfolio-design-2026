---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, year, dateLabel, role, type, tools, client } =
	project.data;

const meta = [
	{ label: 'Year', value: dateLabel ?? String(year) },
	{ label: 'Role', value: role },
	{ label: 'Client', value: client },
	{ label: 'Discipline', value: type.length ? type.join(', ') : undefined },
	{ label: 'Tools', value: tools.length ? tools.join(', ') : undefined },
].filter((m) => m.value);
---

<BaseLayout title={title} description={summary}>
	<article>
		<header class="container project__header">
			<a href="/work" class="project__back">← All work</a>
			<h1 class="project__title">{title}</h1>
			<p class="project__summary measure">{summary}</p>

			<dl class="meta">
				{meta.map((m) => (
					<div class="meta__item">
						<dt>{m.label}</dt>
						<dd>{m.value}</dd>
					</div>
				))}
			</dl>
		</header>

		<div class="container project__body flow measure">
			<Content />
		</div>
	</article>
</BaseLayout>

<style>
	.project__header { padding-block: var(--space-2xl) var(--space-l); }
	.project__back {
		position: relative;
		font-family: var(--font-display);
		font-size: var(--step--1);
		color: var(--ink-muted);
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}
	/* Underline drags in left-to-right */
	.project__back::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1.5px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.25s var(--ease);
	}
	.project__back:hover { color: var(--ink); }
	.project__back:hover::after { transform: scaleX(1); }
	.project__title { font-size: var(--step-5); margin-top: var(--space-m); }
	.project__summary { font-size: var(--step-1); color: var(--ink-muted); margin-top: var(--space-s); }
	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-l);
		margin-top: var(--space-l);
		padding-top: var(--space-m);
		border-top: 1px solid var(--line);
	}
	.meta__item dt {
		font-size: var(--step--1);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-muted);
	}
	.meta__item dd {
		font-family: var(--font-display);
		margin: 0;
	}
	.project__body { padding-bottom: var(--space-2xl); font-size: var(--step-0); }
	.project__body :global(h2) {
		font-size: var(--step-3);
		margin-top: var(--space-xl);
		margin-bottom: var(--space-2xs);
	}
	.project__body :global(h3) {
		font-size: var(--step-1);
		margin-top: var(--space-l);
		margin-bottom: var(--space-2xs);
	}
	.project__body :global(p) { color: var(--ink); }
	.project__body :global(ul) {
		padding-left: 1.2em;
		color: var(--ink-muted);
	}
	.project__body :global(li) { margin-top: var(--space-2xs); }
	.project__body :global(li)::marker { color: var(--accent); }
	.project__body :global(strong) { color: var(--ink); font-weight: 500; }
	.project__body :global(a) { color: var(--accent); }
	.project__body :global(hr) {
		border: 0;
		height: 1px;
		background: var(--line);
		margin-block: var(--space-l);
	}
</style>
