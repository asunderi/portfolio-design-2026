---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, year, role, tools } = project.data;
---

<BaseLayout title={title} description={summary}>
	<article>
		<header class="container project__header">
			<a href="/work" class="project__back">← All work</a>
			<h1 class="project__title">{title}</h1>
			<p class="project__summary measure">{summary}</p>

			<dl class="meta">
				<div class="meta__item">
					<dt>Year</dt>
					<dd>{year}</dd>
				</div>
				<div class="meta__item">
					<dt>Role</dt>
					<dd>{role}</dd>
				</div>
				<div class="meta__item">
					<dt>Tools</dt>
					<dd>{tools.join(', ')}</dd>
				</div>
			</dl>
		</header>

		<div class="container project__body flow measure">
			<Content />
		</div>
	</article>
</BaseLayout>

<style>
	.project__header { padding-block: var(--space-xl) var(--space-l); }
	.project__back {
		font-family: var(--font-display);
		font-size: var(--step--1);
		color: var(--ink-muted);
		text-decoration: none;
	}
	.project__back:hover { color: var(--ink); }
	.project__title { font-size: var(--step-5); margin-top: var(--space-m); }
	.project__summary { font-size: var(--step-1); color: var(--ink-muted); margin-top: var(--space-s); }
	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-l);
		margin-top: var(--space-l);
		padding-top: var(--space-m);
		border-top: 1px solid var(--line);
	}
	.meta__item dt {
		font-size: var(--step--1);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-muted);
	}
	.meta__item dd {
		font-family: var(--font-display);
		margin: 0;
	}
	.project__body { padding-bottom: var(--space-2xl); }
	.project__body :global(h2) { font-size: var(--step-2); margin-top: var(--space-l); }
	.project__body :global(ul) { padding-left: 1.2em; }
	.project__body :global(li) { margin-top: var(--space-2xs); }
</style>
